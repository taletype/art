# ==============================
# Required: Supabase project wiring
# Public keys are safe for browser use. Service/secret keys must stay server-only.
# ==============================
SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_your_project_key
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your_project_key
SUPABASE_ANON_KEY=legacy_anon_key_if_needed
NEXT_PUBLIC_SUPABASE_ANON_KEY=legacy_anon_key_if_needed
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
SUPABASE_SECRET_KEY=your_secret_key_if_needed
SUPABASE_JWT_SECRET=your_jwt_secret_if_needed
POSTGRES_URL=postgres://postgres:password@host:6543/postgres?sslmode=require
POSTGRES_PRISMA_URL=postgres://postgres:password@host:6543/postgres?sslmode=require&pgbouncer=true
POSTGRES_URL_NON_POOLING=postgres://postgres:password@host:5432/postgres?sslmode=require
POSTGRES_HOST=db.your-project-ref.supabase.co
POSTGRES_DATABASE=postgres
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_postgres_password
DATABASE_URL=postgres://postgres:password@host:6543/postgres?sslmode=require

# ==============================
# Required: Thirdweb marketplace UX
# ==============================
NEXT_PUBLIC_THIRDWEB_CLIENT_ID=your_thirdweb_client_id
NEXT_PUBLIC_THIRDWEB_CHAIN=base-sepolia
NEXT_PUBLIC_THIRDWEB_MARKETPLACE_CONTRACT=0x38AA805038446708cF0F5b4bf2089b7e502c612B
NEXT_PUBLIC_THIRDWEB_NFT_COLLECTION_CONTRACT=0xB5992f4c1f847587D30422D1B87e73f23a9EBdc7
THIRDWEB_SECRET_KEY=your_server_secret_if_needed
THIRDWEB_WEBHOOK_SECRET=your_thirdweb_webhook_secret
THIRDWEB_WEBHOOK_TOLERANCE_SECONDS=300

# ==============================
# Optional: API hardening
# If set, callers must send Authorization: Bearer <token>
# ==============================
API_WRITE_BEARER_TOKEN=
API_READ_BEARER_TOKEN=
API_RATE_LIMIT_MAX=30
API_RATE_LIMIT_WINDOW_MS=60000
API_READ_RATE_LIMIT_MAX=60
API_AUCTIONS_RATE_LIMIT_MAX=30
API_AUCTION_BID_RATE_LIMIT_MAX=20

# ==============================
# Optional: real metadata upload adapter
# POST JSON { objectKey, payload, contentType } -> { uri, provider? }
# ==============================
STORAGE_WRITE_ENDPOINT=
STORAGE_BEARER_TOKEN=

# ==============================
# Optional: durable local purchase-state file
# No-DB mode: local file + RPC recovery fallback
# ==============================
PURCHASE_STATE_FILE=.data/purchase-state.json
PURCHASE_STATE_RETENTION_MS=604800000
PURCHASE_STATE_BACKEND=supabase
PURCHASE_STATE_TABLE=purchase_states

# Optional informational vars
STORAGE_PROVIDER=http_or_dev_stub
ARWEAVE_GATEWAY=https://arweave.net
BUNDLR_NODE=https://node1.bundlr.network

# Mock admin/review mode
NEXT_PUBLIC_ENABLE_MOCK_REVIEW=true
NEXT_PUBLIC_ADMIN_WALLET=0xyour_admin_wallet
NEXT_PUBLIC_ADMIN_REVIEWER_WALLET=0xyour_admin_wallet
NEXT_PUBLIC_THIRDWEB_MARKETPLACE_DEPLOY_URL=https://thirdweb.com/thirdweb.eth/MarketplaceV3
NEXT_PUBLIC_THIRDWEB_NFT_COLLECTION_DEPLOY_URL=https://thirdweb.com/thirdweb.eth/TokenERC721

# Optional readiness orchestration overrides
READINESS_ARTIFACT_DIR=artifacts/readiness-v2
READINESS_SMOKE_MODE=validate
