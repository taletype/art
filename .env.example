# ==============================
# Required: Solana RPC
# ==============================
SOLANA_RPC_URL=https://api.devnet.solana.com
NEXT_PUBLIC_SOLANA_RPC_URL=https://api.devnet.solana.com
SOLANA_CLUSTER=devnet

# ==============================
# Required: SDK-backed mint prepare
# ==============================
SOLANA_METAPLEX_CORE_PROGRAM_ID=CoREENxT6tW1HoK8ypY1SxRMZTcVPm7R94rH4PZNhX7d

# ==============================
# Required: SDK-backed list/purchase prepare
# Note: treasury mint support in this MVP is native SOL only
# ==============================
SOLANA_AUCTION_HOUSE_ADDRESS=replace_with_auction_house_address
SOLANA_AUCTION_HOUSE_AUTHORITY=replace_with_auction_house_authority
SOLANA_AUCTION_HOUSE_FEE_ACCOUNT=replace_with_fee_account
SOLANA_AUCTION_HOUSE_TREASURY_ACCOUNT=replace_with_treasury_account
SOLANA_TREASURY_MINT=So11111111111111111111111111111111111111112

# ==============================
# Required: client funding/signing UX
# ==============================
NEXT_PUBLIC_THIRDWEB_CLIENT_ID=your_thirdweb_client_id
THIRDWEB_SECRET_KEY=your_server_secret_if_needed

# ==============================
# Optional: API hardening
# If set, callers must send Authorization: Bearer <token>
# ==============================
API_WRITE_BEARER_TOKEN=
API_READ_BEARER_TOKEN=
API_RATE_LIMIT_MAX=30
API_RATE_LIMIT_WINDOW_MS=60000
API_READ_RATE_LIMIT_MAX=60

# ==============================
# Optional: real metadata upload adapter
# POST JSON { objectKey, payload, contentType } -> { uri, provider? }
# ==============================
STORAGE_WRITE_ENDPOINT=
STORAGE_BEARER_TOKEN=

# ==============================
# Optional: durable local purchase-state file
# No-DB mode: local file + RPC recovery fallback
# ==============================
PURCHASE_STATE_FILE=.data/purchase-state.json
PURCHASE_STATE_RETENTION_MS=604800000

# Optional informational vars
STORAGE_PROVIDER=http_or_dev_stub
ARWEAVE_GATEWAY=https://arweave.net
BUNDLR_NODE=https://node1.bundlr.network

# Mock admin/review mode
NEXT_PUBLIC_ENABLE_MOCK_REVIEW=true
NEXT_PUBLIC_ADMIN_REVIEWER_WALLET=ReviewerWallet111111111111111111111111111

# Optional readiness orchestration overrides
READINESS_ARTIFACT_DIR=artifacts/readiness-v2
READINESS_SMOKE_MODE=validate
